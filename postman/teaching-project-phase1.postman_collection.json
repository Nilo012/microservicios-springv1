{
  "info": {
    "_postman_id": "7c0d90aa-2878-4cf6-a8c7-f6c5d672d001",
    "name": "Teaching Project Phase 1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the phase 1 Spring Boot APIs: product-service and order-service."
  },
  "item": [
    {
      "name": "Product Service",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mechanical Keyboard\",\n  \"sku\": \"KEY-001\",\n  \"price\": 89.90\n}"
            },
            "url": {
              "raw": "{{productServiceUrl}}/api/products",
              "host": [
                "{{productServiceUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            },
            "description": "Creates a new product in product-service."
          },
          "response": []
        },
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{productServiceUrl}}/api/products",
              "host": [
                "{{productServiceUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            },
            "description": "Lists all products."
          },
          "response": []
        },
        {
          "name": "Get Product By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{productServiceUrl}}/api/products/{{productId}}",
              "host": [
                "{{productServiceUrl}}"
              ],
              "path": [
                "api",
                "products",
                "{{productId}}"
              ]
            },
            "description": "Gets a single product by id."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Order Service",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{orderServiceUrl}}/api/orders",
              "host": [
                "{{orderServiceUrl}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            },
            "description": "Creates an order after resolving the product through the Feign client."
          },
          "response": []
        },
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{orderServiceUrl}}/api/orders",
              "host": [
                "{{orderServiceUrl}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            },
            "description": "Lists all orders."
          },
          "response": []
        },
        {
          "name": "Get Order By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{orderServiceUrl}}/api/orders/{{orderId}}",
              "host": [
                "{{orderServiceUrl}}"
              ],
              "path": [
                "api",
                "orders",
                "{{orderId}}"
              ]
            },
            "description": "Gets a single order by id."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "productServiceUrl",
